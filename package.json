{
  "name": "life-design-system-root",
  "private": true,
  "version": "1.0.0",
  "description": "Life Design System Monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync-tokens": "npm run sync-tokens --workspace=@life-ds/tokens",
    "sync-icons": "npm run sync-icons --workspace=@life-ds/icons",
    "sync-skills": "rm -rf packages/skills/content && mkdir -p packages/skills/content && cp -R skills/. packages/skills/content/"
  },
  "dependencies": {
    "@life-ds/components-web": "^1.2.1",
    "@life-ds/icons": "^1.0.4",
    "@life-ds/skills": "^1.2.1",
    "@life-ds/tokens": "^1.2.1"
  }
}
