{
  "name": "life-design-system-root",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "life-design-system-root",
      "version": "1.0.0",
      "workspaces": [
        "packages/*"
      ],
      "dependencies": {
        "@life-ds/icons": "^1.0.2",
        "@life-ds/skills": "^1.0.10",
        "@life-ds/tokens": "^1.0.3"
      },
      "devDependencies": {}
    },
    "node_modules/@life-ds/components-web": {
      "resolved": "packages/components-web",
      "link": true
    },
    "node_modules/@life-ds/icons": {
      "resolved": "packages/icons",
      "link": true
    },
    "node_modules/@life-ds/skills": {
      "resolved": "packages/skills",
      "link": true
    },
    "node_modules/@life-ds/tokens": {
      "resolved": "packages/tokens",
      "link": true
    },
    "packages/components-web": {
      "name": "@life-ds/components-web",
      "version": "1.0.6",
      "license": "ISC",
      "dependencies": {
        "@life-ds/icons": "^1.0.0",
        "@life-ds/tokens": "^1.0.0"
      },
      "bin": {
        "life-ds": "bin/cli.mjs"
      }
    },
    "packages/icons": {
      "name": "@life-ds/icons",
      "version": "1.0.2"
    },
    "packages/skills": {
      "name": "@life-ds/skills",
      "version": "1.0.11",
      "license": "ISC",
      "bin": {
        "life-ds-skills": "bin/cli.mjs"
      }
    },
    "packages/tokens": {
      "name": "@life-ds/tokens",
      "version": "1.0.3",
      "license": "ISC"
    }
  }
}
